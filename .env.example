# GHL Agency API Key (Settings > API Keys in your Agency account)
GHL_API_KEY=your_agency_api_key_here

# Your GHL Company/Agency ID
GHL_COMPANY_ID=your_company_id_here

# Master Snapshot ID (from Snapshots section in Agency view)
MASTER_SNAPSHOT_ID=your_snapshot_id_here

# Google Docs API (Service Account JSON key file path)
# Optional - only needed if parsing Google Docs automatically
GOOGLE_SERVICE_ACCOUNT_KEY=./google-service-account.json

# Port for the web server
PORT=3000
